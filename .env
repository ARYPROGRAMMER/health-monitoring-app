# Stealthera runtime config — no secrets here.
# Firebase config lives in lib/firebase_options.dart + native google-services.json.
#
# Leave API_BASE_URL blank to use the built-in default backend. Set it to your
# own backend to override (the /api suffix is added automatically). When blank,
# the STEALTHERA_API_BASE_URL --dart-define is used if provided (CI).
API_BASE_URL=
POLL_INTERVAL_SECONDS=60
DEFAULT_TIMEOUT_SECONDS=45
ENABLE_VERBOSE_LOGGING=false
