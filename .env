# Stealthera runtime config — no secrets here.
# Firebase config lives in lib/firebase_options.dart + native google-services.json.
#
# API_BASE_URL: the backend host. The /v1/api prefix is added automatically, so
# just give the host. Leave blank to use the built-in default. When blank, the
# STEALTHERA_API_BASE_URL --dart-define is used if provided (CI).
#   Local dev (desktop/web):   http://localhost:3000
#   Android emulator -> local: http://10.0.2.2:3000
API_BASE_URL=
# Optional X-API-Key for backends with REQUIRE_API_KEY=true.
API_KEY=
# Display timezone passed to the API (?tz=).
DISPLAY_TIMEZONE=Asia/Kolkata
# Foreground refresh cadence + realtime polling fallback (seconds).
POLL_INTERVAL_SECONDS=20
DEFAULT_TIMEOUT_SECONDS=45
ENABLE_VERBOSE_LOGGING=false
